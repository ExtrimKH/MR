# Скопируй в .env (локально) или впиши в настройки Render (вкладка Environment).
# Если переменные не заданы — сайт работает локально: фото на диске, данные в файле.

# Пароль администратора (ОБЯЗАТЕЛЬНО поменяй)
ADMIN_PASSWORD=придумай-надёжный-пароль

# Секрет для cookie сессии (любая длинная случайная строка)
SESSION_SECRET=случайная-длинная-строка

# --- Cloudinary (хранение фото) ---
# Берётся одной строкой в дашборде Cloudinary: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# --- Upstash Redis (хранение товаров и текстов) ---
# Из дашборда Upstash, раздел REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
